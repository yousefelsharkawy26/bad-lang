class Animal {
    var name : string;
    var age : number;

    func __init(name : string, age : number) {
        this.name = name;
        this.age = age;
    }

    func speak() {
        print("Generic animal sound");
    }
}

class Dog : Animal {
    var breed : string;

    func __init(name : string, age : number, breed : string) {
        super.__init(name, age);
        this.breed = breed;
    }

    func speak() {
        print("Woof!");
    }
}

var d = new Dog("Buddy", 5, "Golden");
print(d.name);
print(d.age);
print(d.breed);
d.speak();
