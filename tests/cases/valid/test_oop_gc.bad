// test_oop_gc.bad - Integration test for OOP + GC in native LLVM backend

class Counter {
    var value;

    fun init(start) {
        this.value = start;
    }

    fun increment() {
        this.value = this.value + 1;
    }

    fun get() {
        return this.value;
    }
}

class Accumulator {
    var total;

    fun init() {
        this.total = 0;
    }

    fun add(n) {
        this.total = this.total + n;
    }

    fun result() {
        return this.total;
    }
}

// Basic OOP: create an object, call methods
var c = new Counter(10);
c.increment();
c.increment();
c.increment();
print("Counter after 3 increments (expect 13):", c.get());

// Stress GC: create many objects in a loop (GC should reclaim automatically)
var acc = new Accumulator();
var i = 0;
while (i < 100) {
    var temp = new Counter(i);
    temp.increment();
    acc.add(temp.get());
    i = i + 1;
}
// sum of (0+1) + (1+1) + ... + (99+1) = sum of 1..100 = 5050
print("Accumulator result (expect 5050):", acc.result());

// Nested: counter of a counter value
var a = new Counter(0);
var b = new Counter(0);
a.increment();
a.increment();
b.increment();
var nested = new Counter(a.get() + b.get()); // 2 + 1 = 3
print("Nested counter (expect 3):", nested.get());

print("All OOP + GC tests passed!");
